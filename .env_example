# .env.example
# Plantilla para configuración del proyecto
# Copia este archivo como .env y completa con tus datos

# Configuración de la base de datos
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sakila

# Configuración de excel Dashboard
EXCEL_FILE=dashboard/Sakila_Dashboard.xlsx
OUTPUT_FOLDER=output
AUTO_OPEN_EXCEL=true